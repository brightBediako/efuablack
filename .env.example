# Public site URL (used for metadata, sitemap, robots). No trailing slash.
NEXT_PUBLIC_SITE_URL=https://efuablack.com

# MongoDB (booking, contact, subscribers)
MONGODB_URI=mongodb+srv://USER:PASSWORD@cluster.example.mongodb.net/efuablack?retryWrites=true&w=majority

# Inbox for admin notifications (booking + contact)
NOTIFY_EMAIL=you@example.com

# Transactional email (SMTP). Optional in dev — emails are skipped if unset.
EMAIL_FROM=noreply@efuablack.com
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-address@gmail.com
SMTP_PASS=your-app-password

# reCAPTCHA v3 (https://www.google.com/recaptcha/admin). For production, set both.
# When RECAPTCHA_SECRET_KEY is set, APIs require a valid client token.
NEXT_PUBLIC_RECAPTCHA_SITE_KEY=
RECAPTCHA_SECRET_KEY=
# Optional: min score 0–1 (default 0.5). Stricter = higher number.
# RECAPTCHA_MIN_SCORE=0.5

# Optional: salt for hashing IPs in rate-limit records (recommended in production).
# RATE_LIMIT_SALT=

# Admin UI at /admin — set a strong password in production.
ADMIN_PASSWORD=
# Optional: separate secret for signing admin session cookies (defaults to ADMIN_PASSWORD).
# ADMIN_SESSION_SECRET=
